{
  "$schema": "https://json.schemastore.org/claude-code-marketplace.json",
  "name": "honeycomb",
  "description": "sunxiao 的 Claude Code 能力集 —— skills、agents、commands、hooks 的蜂巢式集合",
  "owner": {
    "name": "sunxiao",
    "email": "sunxiaoyes@outlook.com",
    "url": "https://github.com/TNT-Likely"
  },
  "plugins": [
    {
      "name": "fastapi-vite-saas",
      "source": "./plugins/fastapi-vite-saas",
      "displayName": "FastAPI + Vite SaaS",
      "description": "脚手架技能:基于 BeeCount-Cloud 的 FastAPI + Vite 前端 + Docker + GitHub Actions monorepo 模式,生成新项目并按领域语义改造。",
      "version": "0.1.0",
      "author": {
        "name": "sunxiao",
        "email": "sunxiaoyes@outlook.com",
        "url": "https://github.com/TNT-Likely"
      },
      "homepage": "https://github.com/TNT-Likely/honeycomb/tree/main/plugins/fastapi-vite-saas",
      "repository": "https://github.com/TNT-Likely/honeycomb",
      "license": "MIT",
      "keywords": ["scaffold", "monorepo", "fastapi", "vite", "docker", "github-actions"],
      "category": "scaffolding"
    },
    {
      "name": "flutter-riverpod-drift",
      "source": "./plugins/flutter-riverpod-drift",
      "displayName": "Flutter + Riverpod + Drift",
      "description": "脚手架技能:Flutter app + Riverpod 状态管理 + Drift 本地 DB + 可选云同步,带 Design Token / Repository 多端切换 / 严格迁移纪律等成熟模式。脱胎于 BeeCount 生产实践。",
      "version": "0.1.0",
      "author": {
        "name": "sunxiao",
        "email": "sunxiaoyes@outlook.com",
        "url": "https://github.com/TNT-Likely"
      },
      "homepage": "https://github.com/TNT-Likely/honeycomb/tree/main/plugins/flutter-riverpod-drift",
      "repository": "https://github.com/TNT-Likely/honeycomb",
      "license": "MIT",
      "keywords": ["scaffold", "flutter", "riverpod", "drift", "mobile-app", "design-tokens", "repository-pattern"],
      "category": "scaffolding"
    },
    {
      "name": "github-issue-triage",
      "source": "./plugins/github-issue-triage",
      "displayName": "GitHub Issue Triage",
      "description": "GitHub issue 治理工具集:triage(全量四级分流→优先级文档,可 /schedule 定期巡检)+ analyze-issue(单条深度分析:是否真 bug / 要不要修 / 优先级 / 功能请求是否合理,bug 结合代码验证)。",
      "version": "0.1.0",
      "author": {
        "name": "sunxiao",
        "email": "sunxiaoyes@outlook.com",
        "url": "https://github.com/TNT-Likely"
      },
      "homepage": "https://github.com/TNT-Likely/honeycomb/tree/main/plugins/github-issue-triage",
      "repository": "https://github.com/TNT-Likely/honeycomb",
      "license": "MIT",
      "keywords": ["github", "issue", "triage", "backlog", "prioritization", "gh-cli"],
      "category": "productivity"
    }
  ]
}
